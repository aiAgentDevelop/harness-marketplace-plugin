{
  "hooks": {
    "PreToolUse": [
      {{CONDITION:enforcement_protected_files}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/protected-files.sh",
            "timeout": 5
          }
        ]
      },
      {{/CONDITION:enforcement_protected_files}}
      {{CONDITION:enforcement_secret_guard}}
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/secret-guard.sh",
            "timeout": 10
          }
        ]
      },
      {{/CONDITION:enforcement_secret_guard}}
      {{CONDITION:enforcement_pattern_guard}}
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/pattern-guard.sh",
            "timeout": 10
          }
        ]
      },
      {{/CONDITION:enforcement_pattern_guard}}
      {{CONDITION:has_database}}
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/db-safety.sh",
            "timeout": 5
          }
        ]
      }
      {{/CONDITION:has_database}}
    ],
    "PostToolUse": [
      {{CONDITION:has_lint}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/post-edit-lint.sh",
            "timeout": 30
          }
        ]
      },
      {{/CONDITION:has_lint}}
      {{CONDITION:has_typecheck}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/post-edit-typecheck.sh",
            "timeout": 30
          }
        ]
      },
      {{/CONDITION:has_typecheck}}
      {{CONDITION:has_formatter}}
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/post-edit-format.sh",
            "timeout": 15
          }
        ]
      }
      {{/CONDITION:has_formatter}}
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/project-harness/hooks/session-init.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
