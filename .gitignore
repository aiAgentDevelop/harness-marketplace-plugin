node_modules/
*.log
.DS_Store
Thumbs.db
/.claude/

# Keep benchmark batch logs (referenced by phase05-report.md)
!benchmarks/results/*.log

# Raw per-run artifacts are large (embedded git repos) — exclude from VCS.
# Aggregated data (phase05-report.md, aggregated.json, probe.json, scored/*.json)
# is committed for reproducibility.
benchmarks/results/raw/
benchmarks/results/probe-events.jsonl
# batch.log is per-batch execution log; the !*.log exception above would
# otherwise keep it, but it's runtime-only and often corrupted by concurrent runs.
benchmarks/results/batch.log
