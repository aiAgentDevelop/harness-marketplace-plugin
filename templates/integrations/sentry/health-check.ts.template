import type { NextRequest } from "next/server";

type CheckStatus = "ok" | "degraded" | "down";

export async function GET(_req: NextRequest) {
  const checks: Record<string, CheckStatus> = {
    process: "ok",
  };

  // {{CONDITION:has_database}}
  // Database check — keep under 200ms so the probe isn't misleading.
  try {
    // TODO: replace with your DB ping (e.g., `await db.raw("SELECT 1")`).
    checks.database = "ok";
  } catch {
    checks.database = "down";
  }
  // {{/CONDITION:has_database}}

  // {{CONDITION:has_cache}}
  try {
    // TODO: replace with your cache ping (e.g., `await redis.ping()`).
    checks.cache = "ok";
  } catch {
    checks.cache = "degraded"; // cache down shouldn't fail the readiness probe
  }
  // {{/CONDITION:has_cache}}

  const hasFailure = Object.values(checks).includes("down");
  const status = hasFailure ? 503 : 200;

  return Response.json(
    {
      status: hasFailure ? "down" : "ok",
      release: process.env.SENTRY_RELEASE ?? "unknown",
      checks,
      timestamp: new Date().toISOString(),
    },
    { status },
  );
}

