// Required env vars:
//   SENTRY_DSN         — your Sentry project DSN
//   SENTRY_RELEASE     — release identifier (typically git SHA, set in CI)
//   NODE_ENV           — production | staging | development
// ============================================================================

import * as Sentry from "@sentry/node";
import { nodeProfilingIntegration } from "@sentry/profiling-node";

Sentry.init({
  dsn: process.env.SENTRY_DSN,
  environment: process.env.NODE_ENV ?? "development",
  release: process.env.SENTRY_RELEASE,
  integrations: [
    nodeProfilingIntegration(),
  ],
  tracesSampleRate: {{TRACES_SAMPLE_RATE}},
  profilesSampleRate: {{PROFILES_SAMPLE_RATE}},
  // Scrub common PII before send.
  beforeSend(event) {
    if (event.user) {
      delete event.user.ip_address;
      delete event.user.email;
    }
    return event;
  },
});

// Catch uncaught exceptions and unhandled promise rejections.
// Without these, async throws on background paths disappear silently.
process.on("uncaughtException", (err) => {
  Sentry.captureException(err);
});

process.on("unhandledRejection", (reason) => {
  Sentry.captureException(reason);
});

// ═══ CUSTOM RULES BELOW (preserved on upgrade) ═══
