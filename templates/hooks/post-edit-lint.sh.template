#!/usr/bin/env bash
# ============================================================================
# Post-Edit Lint Runner — v{{VERSION}}
# Event: PostToolUse | Matcher: Edit,Write
# Generated by {{PROJECT_NAME}} harness-marketplace plugin
# ============================================================================
set -uo pipefail

# ═══ GENERATED RULES (overwritten on upgrade) ═══

FILE_PATH="${1:-}"

if [[ -z "$FILE_PATH" ]]; then
  exit 0
fi

# Normalize path separators
FILE_PATH="${FILE_PATH//\\//}"

# Only lint source files
case "$FILE_PATH" in
  *.ts|*.tsx|*.js|*.jsx|*.vue|*.svelte|*.py|*.rb|*.go|*.rs|*.css|*.scss|*.less)
    ;;
  *)
    exit 0
    ;;
esac

# Check if file exists
if [[ ! -f "$FILE_PATH" ]]; then
  exit 0
fi

# Run lint command on the specific file
LINT_CMD="{{LINT_COMMAND}}"

if [[ -z "$LINT_CMD" ]]; then
  exit 0
fi

# Replace common placeholders with the actual file path
# Supports patterns like: eslint --fix {file}, ruff check {file}, etc.
if echo "$LINT_CMD" | grep -q '{file}'; then
  LINT_CMD="${LINT_CMD//\{file\}/"$FILE_PATH"}"
else
  # Append file path if no placeholder
  LINT_CMD="$LINT_CMD \"$FILE_PATH\""
fi

echo "[LINT] Running linter on $(basename "$FILE_PATH")..."

LINT_OUTPUT=""
LINT_OUTPUT=$(eval "$LINT_CMD" 2>&1) || true
LINT_EXIT=$?

if [[ -n "$LINT_OUTPUT" ]]; then
  echo "$LINT_OUTPUT"
fi

if [[ "$LINT_EXIT" -ne 0 ]]; then
  echo "[LINT] Linter reported issues in '$FILE_PATH' (exit code: $LINT_EXIT)"
  echo "[LINT] Review the issues above and fix them if appropriate."
fi

# ═══ CUSTOM RULES BELOW (preserved on upgrade) ═══

# Add your own post-edit lint rules here.
# They will be preserved when the plugin is upgraded.
#
# Example: Run a project-specific linter for certain paths
#   case "$FILE_PATH" in
#     */api/*)
#       echo "[LINT] Running API-specific linter..."
#       npx api-linter "$FILE_PATH" 2>&1 || true
#       ;;
#   esac

# Non-blocking: always exit 0
exit 0
