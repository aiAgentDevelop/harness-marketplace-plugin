#!/usr/bin/env bash
# ============================================================================
# Database Safety Guard — v{{VERSION}}
# Event: PreToolUse | Matcher: Bash
# Generated by {{PROJECT_NAME}} harness-marketplace plugin
# ============================================================================
set -euo pipefail

# ═══ GENERATED RULES (overwritten on upgrade) ═══

{{CONDITION:has_database}}

COMMAND="${1:-}"

if [[ -z "$COMMAND" ]]; then
  echo "db-safety: no command provided"
  exit 0
fi

# Convert command to uppercase for case-insensitive matching
COMMAND_UPPER="$(echo "$COMMAND" | tr '[:lower:]' '[:upper:]')"

# --- Dangerous SQL patterns ---

# DROP TABLE
if echo "$COMMAND_UPPER" | grep -qE 'DROP\s+TABLE'; then
  echo "[DB-SAFETY] Dangerous SQL detected: DROP TABLE"
  echo "Command: $COMMAND"
  echo "This operation would permanently destroy a database table."
  echo "If this is intentional, run the command manually outside of Claude."
  exit 1
fi

# DROP DATABASE
if echo "$COMMAND_UPPER" | grep -qE 'DROP\s+DATABASE'; then
  echo "[DB-SAFETY] Dangerous SQL detected: DROP DATABASE"
  echo "Command: $COMMAND"
  echo "This operation would permanently destroy an entire database."
  exit 1
fi

# TRUNCATE
if echo "$COMMAND_UPPER" | grep -qE 'TRUNCATE\s'; then
  echo "[DB-SAFETY] Dangerous SQL detected: TRUNCATE"
  echo "Command: $COMMAND"
  echo "This operation would remove all rows from a table."
  exit 1
fi

# DELETE FROM without WHERE clause
if echo "$COMMAND_UPPER" | grep -qE 'DELETE\s+FROM\s' && ! echo "$COMMAND_UPPER" | grep -qE 'DELETE\s+FROM\s+\S+\s+WHERE'; then
  echo "[DB-SAFETY] Dangerous SQL detected: DELETE FROM without WHERE clause"
  echo "Command: $COMMAND"
  echo "This would delete ALL rows from a table. Add a WHERE clause."
  exit 1
fi

# ALTER TABLE DROP COLUMN
if echo "$COMMAND_UPPER" | grep -qE 'ALTER\s+TABLE\s+\S+\s+DROP\s+COLUMN'; then
  echo "[DB-SAFETY] Potentially dangerous SQL detected: ALTER TABLE ... DROP COLUMN"
  echo "Command: $COMMAND"
  echo "This operation would permanently remove a column and its data."
  exit 1
fi

# --- Direct DB connection strings in commands ---

# Check for connection strings that may contain credentials
if echo "$COMMAND" | grep -qE '(mysql|psql|mongo|redis-cli)\s.*(-p\s|--password|://)'; then
  echo "[DB-SAFETY] Direct database connection with credentials detected."
  echo "Avoid passing credentials directly in commands."
  echo "Use environment variables or connection profiles instead."
  exit 1
fi

# Check for database URLs with embedded credentials
if echo "$COMMAND" | grep -qE '(postgres|mysql|mongodb|redis)://[^/]*:[^/]*@'; then
  echo "[DB-SAFETY] Database connection string with embedded credentials detected."
  echo "Use environment variables for connection strings instead."
  exit 1
fi

{{/CONDITION:has_database}}

# ═══ CUSTOM RULES BELOW (preserved on upgrade) ═══

# Add your own database safety rules here.
# They will be preserved when the plugin is upgraded.
#
# Example:
#   if echo "$COMMAND_UPPER" | grep -qE 'UPDATE\s+users\s+SET.*role.*admin'; then
#     echo "[DB-SAFETY] Custom rule: bulk admin role assignment blocked"
#     exit 1
#   fi

exit 0
